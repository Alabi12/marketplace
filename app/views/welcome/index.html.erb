<div class="min-h-screen bg-white">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-r from-indigo-600 to-purple-700 text-white py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6 animate-fade-in">
        Welcome to <span class="text-indigo-200">Marketplace Pro</span>
      </h1>
      <p class="text-xl md:text-2xl max-w-3xl mx-auto opacity-90 mb-10 animate-fade-in-up delay-100">
        The all-in-one platform for businesses, professionals, and service providers
      </p>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4 animate-fade-in-up delay-200">
        <% if user_signed_in? %>
          <%= link_to 'Go to Dashboard', dashboard_path, 
              class: 'px-8 py-4 bg-white text-indigo-700 font-semibold rounded-lg shadow-lg hover:bg-indigo-50 transition-all transform hover:-translate-y-1' %>
        <% else %>
          <%= link_to 'Sign Up', new_user_registration_path, 
              class: 'px-8 py-4 bg-white text-indigo-700 font-semibold rounded-lg shadow-lg hover:bg-indigo-50 transition-all transform hover:-translate-y-1' %>
          <%= link_to 'Login', new_user_session_path, 
              class: 'px-8 py-4 bg-transparent border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:bg-opacity-10 transition-all transform hover:-translate-y-1' %>
        <% end %>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-white transform skew-y-1 -mb-8 z-10"></div>
  </section>

  <!-- Features Grid -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-900 mb-16">
        Our <span class="text-indigo-600">Platform Features</span>
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-2">
          <div class="p-8">
            <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <i class="fas fa-store text-indigo-600 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold text-center text-gray-900 mb-3">Online Stores</h3>
            <p class="text-gray-600 text-center mb-6">Create your digital storefront and sell products with ease.</p>
            <%= link_to features_path(anchor: 'stores'), 
                class: 'text-indigo-600 font-medium flex items-center justify-center group' do %>
              Explore <i class="fas fa-arrow-right ml-2 group-hover:ml-3 transition-all"></i>
            <% end %>
          </div>
        </div>
        
        <!-- Feature 2 -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-2">
          <div class="p-8">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <i class="fas fa-briefcase text-green-600 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold text-center text-gray-900 mb-3">Professional Services</h3>
            <p class="text-gray-600 text-center mb-6">Market and schedule your professional services.</p>
            <%= link_to features_path(anchor: 'services'), 
                class: 'text-green-600 font-medium flex items-center justify-center group' do %>
              Explore <i class="fas fa-arrow-right ml-2 group-hover:ml-3 transition-all"></i>
            <% end %>
          </div>
        </div>
        
        <!-- Feature 3 -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-2">
          <div class="p-8">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <i class="fas fa-hands-helping text-blue-600 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold text-center text-gray-900 mb-3">Skilled Professionals</h3>
            <p class="text-gray-600 text-center mb-6">Connect with skilled tradespeople in your area.</p>
            <%= link_to professional_profiles_path, 
                class: 'text-blue-600 font-medium flex items-center justify-center group' do %>
              Explore <i class="fas fa-arrow-right ml-2 group-hover:ml-3 transition-all"></i>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-900 mb-16">
        What Our <span class="text-indigo-600">Users Say</span>
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300">
          <div class="flex text-yellow-400 mb-4">
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
          </div>
          <p class="text-gray-700 italic mb-6">"This platform helped me grow my client base by 200% in just 3 months!"</p>
          <div class="flex items-center">
            <div class="bg-indigo-100 w-12 h-12 rounded-full flex items-center justify-center mr-4">
              <span class="text-indigo-600 font-bold">SJ</span>
            </div>
            <div>
              <h4 class="font-bold text-gray-900">Sarah J.</h4>
              <p class="text-gray-600 text-sm">Hair Stylist</p>
            </div>
          </div>
        </div>
        
        <!-- Testimonial 2 -->
        <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300">
          <div class="flex text-yellow-400 mb-4">
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star-half-alt"></i>
          </div>
          <p class="text-gray-700 italic mb-6">"The scheduling system saves me hours every week. Highly recommended!"</p>
          <div class="flex items-center">
            <div class="bg-indigo-100 w-12 h-12 rounded-full flex items-center justify-center mr-4">
              <span class="text-indigo-600 font-bold">MT</span>
            </div>
            <div>
              <h4 class="font-bold text-gray-900">Michael T.</h4>
              <p class="text-gray-600 text-sm">Business Consultant</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-indigo-600 to-purple-700 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Get Started?</h2>
      <p class="text-xl opacity-90 mb-10">Join thousands of professionals growing their business with our platform</p>
      <%= link_to 'Create Your Account', new_user_registration_path, 
          class: 'inline-block px-8 py-4 bg-white text-indigo-700 font-semibold rounded-lg shadow-lg hover:bg-indigo-50 transition-all transform hover:-translate-y-1' %>
    </div>
  </section>
</div>

<!-- Add these styles for animations -->
<style>
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }
  .delay-100 {
    animation-delay: 0.1s;
  }
  .delay-200 {
    animation-delay: 0.2s;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fadeInUp {
    from { 
      opacity: 0;
      transform: translateY(20px);
    }
    to { 
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>